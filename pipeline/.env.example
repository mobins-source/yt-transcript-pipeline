# YouTube channel(s) to process — comma-separated channel handles or IDs
YOUTUBE_CHANNELS=@mcctucson

# YouTube playlist IDs to fetch — comma-separated (alternative to full channel)
# Use this to fetch only specific playlists from a channel (e.g. a single sheikh)
# Leave empty to use channel mode only
YOUTUBE_PLAYLISTS=

# Language preference for transcripts (ISO 639-1 code)
TRANSCRIPT_LANG=en

# How many videos to fetch per channel per run (0 = all)
# For scheduled runs, keep this at 20 to avoid IP blocks
MAX_VIDEOS_PER_CHANNEL=20

# ── Batch strategy (avoids YouTube IP blocks) ─────────────────────────────────
# Process BATCH_SIZE videos, pause BATCH_PAUSE seconds, repeat
BATCH_SIZE=10
BATCH_PAUSE=180

# Data directory (relative to pipeline/)
DATA_DIR=../data

# YouTube Data API v3 key — enables fetching ALL videos (not just latest 15)
YOUTUBE_API_KEY=

# Anthropic API key for AI enrichment
ANTHROPIC_API_KEY=

# Browser to load cookies from (leave empty to disable)
COOKIE_BROWSER=
